Include ~/.colima/ssh_config

IgnoreUnknown UseKeychain

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host github-personal
  HostName github.com
  User git
  # Current machine: id_ed25519_personal (Rishikhesh account) is tried first.
  # New machine: only id_ed25519 exists, so the missing line is skipped and it is used.
  IdentityFile ~/.ssh/id_ed25519_personal
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes